OPENAI_API_KEY=
MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
PORT=3000

# Crawling
MAX_PAGES=25
MAX_CHARS_PER_PAGE=12000
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Email settings (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
STAFF_EMAIL=
FROM_EMAIL=
GOOGLE_CHAT_WEBHOOK_URL=

# Web embed/API
CORS_ORIGIN=

# Storage backend
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=clinic-ai

# Intake protection
INTAKE_RATE_LIMIT_MAX=5
INTAKE_RATE_LIMIT_WINDOW_MS=900000
